# Terminal Miku 3D runtime preferences
# 적용 시점: start/run 실행 직전

# ui_language = ko | en
ui_language = ko

# Ghostty font:
# - reset: 시작 전에 Cmd+0 1회
# - steps: reset 이후 Cmd+= / Cmd+- 반복 횟수
ghostty_font_reset = false
ghostty_font_steps = 0

# Visual / Sync:
# - cell_aspect_mode: auto | manual
# - cell_aspect_trim: auto 모드 보정 배율 (0.70..1.30)
# - contrast_profile: adaptive | fixed
# - sync_offset_ms: 오디오 대비 애니메이션 오프셋(ms)
# - sync_speed_mode: auto | realtime
cell_aspect_mode = auto
cell_aspect_trim = 1.00
contrast_profile = adaptive
sync_offset_ms = 0
sync_speed_mode = auto

# Renderer tuning:
# - triangle_stride: 1이면 전체 삼각형, 2면 절반(성능↑ 디테일↓)
# - min_triangle_area_px2: 화면 픽셀 기준으로 너무 작은 삼각형 스킵
triangle_stride = 1
min_triangle_area_px2 = 0.00
